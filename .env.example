# Copy to .env and adjust as needed.

# --- Backend ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/internal_ops
SESSION_SECRET=replace-me-with-a-long-random-string
APP_ENV=development
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:5173

# --- Placeholder provider credentials (NOT used by mocks; here for future real integrations) ---
PERSONA_API_KEY=
STRIPE_IDENTITY_API_KEY=
STRIPE_API_KEY=
ADYEN_API_KEY=

